PORT=3000

# From Meta App Dashboard → Settings → Basic
META_APP_SECRET=your_app_secret_here

# You invent this yourself, paste the same value in Meta Dashboard
META_VERIFY_TOKEN=your_verify_token_here

# From Meta → WhatsApp → API Setup
META_WHATSAPP_TOKEN=your_whatsapp_token_here
META_PHONE_NUMBER_ID=your_phone_number_id_here

# From Google AI Studio → aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# Your MySQL database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_db_password
DB_NAME=mdtours_bot

# Admin dashboard password → visit /admin to view leads
ADMIN_PASSWORD=change_this_password
